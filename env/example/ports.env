# Host-side ports for the dev/local Docker infra. Container-internal ports
# stay standard; only the host-side mapping is configurable so the stack can
# coexist with other projects already sitting on 5432/5672/6379.
#
# Sourced by Makefile (`set -a; source ports.env; set +a`) before compose and
# before backend `air` launch. Because the backend connection ports are
# derived from the same vars, edit one file and both halves stay in sync.

export MY_PROJECT_PG_PORT="5432"
export MY_PROJECT_RABBITMQ_PORT="5672"
export MY_PROJECT_RABBITMQ_MGMT_PORT="15672"
export MY_PROJECT_REDIS_PORT="6379"

# Host ports for the app services (make run-docker, the "app" compose profile).
export MY_PROJECT_BACKEND_PORT="8000"
export MY_PROJECT_FRONTEND_PORT="5173"

# Backend connects to the same port the host exposes when run locally.
# api.env intentionally does NOT pin these so this file is the single source
# of truth. Container-internal services (rabbit init, redis init) still use
# the standard ports inside the docker network.
export MY_PROJECT_API_POSTGRESQL_PORT="$MY_PROJECT_PG_PORT"
export MY_PROJECT_API_RABBITMQ_PORT="$MY_PROJECT_RABBITMQ_PORT"
export MY_PROJECT_API_REDIS_PORT="$MY_PROJECT_REDIS_PORT"
