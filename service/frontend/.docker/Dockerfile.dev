FROM node:22-alpine AS dev
WORKDIR /app
# Install deps in the image; the source (incl. node_modules anon volume) is
# mounted at runtime for hot reload. package-lock.json is optional.
COPY package.json package-lock.json* ./
RUN npm install
EXPOSE 5173
# --host binds 0.0.0.0 so the dev server is reachable from the host.
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
