# Build the SPA, then serve the static bundle with nginx. nginx also proxies
# /api to the backend container (alias "backend"), so the app is same-origin
# and the SPA can use a relative /api/v1 base (see vite.config.ts).
FROM node:22-alpine AS build
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm install
COPY . .
RUN npm run build

FROM nginx:1.27-alpine AS prod
COPY --from=build /app/dist /usr/share/nginx/html
COPY .docker/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
