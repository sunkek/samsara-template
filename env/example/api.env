export MY_PROJECT_API_HEALTH_PORT="3333"
export MY_PROJECT_API_HEALTH_INTERVAL="30s"

export MY_PROJECT_API_LOG_LEVEL="debug"
export MY_PROJECT_API_LOG_SOURCE="false"

export MY_PROJECT_API_FIBER_HOST="localhost"
export MY_PROJECT_API_FIBER_PORT="8000"
export MY_PROJECT_API_FIBER_PATH_PREFIX="/api/v1"
export MY_PROJECT_API_FIBER_BODY_LIMIT_MB="20"
# Server timeouts (slowloris protection). 0 disables a given timeout.
export MY_PROJECT_API_FIBER_READ_TIMEOUT="15s"
export MY_PROJECT_API_FIBER_WRITE_TIMEOUT="30s"
export MY_PROJECT_API_FIBER_IDLE_TIMEOUT="120s"
# CORS. "*" is fine for local dev. For stage/prod set explicit origins —
# a wildcard origin on an authenticated API is unsafe (see CLAUDE.md).
export MY_PROJECT_API_FIBER_CORS_ALLOW_ORIGINS="*"
export MY_PROJECT_API_FIBER_CORS_ALLOW_METHODS="*"
export MY_PROJECT_API_FIBER_CORS_ALLOW_HEADERS="*"
# Swagger UI + swagger.json are served unauthenticated at /docs when this is
# set. Leave empty in stage/prod to disable the public API browser.
export MY_PROJECT_API_FIBER_SWAGGER_FILE_PATH="./docs/swagger.json"

export MY_PROJECT_API_POSTGRESQL_HOST="localhost"
# Port comes from env/<env>/ports.env, sourced by Makefile.
export MY_PROJECT_API_POSTGRESQL_NAME="my_project"
export MY_PROJECT_API_POSTGRESQL_USER="my_project"
export MY_PROJECT_API_POSTGRESQL_PASS="password"
export MY_PROJECT_API_POSTGRESQL_CONNECT_TIMEOUT="10s"
# "disable" is fine for in-network docker. Set "require" (or "verify-full")
# when the DB is reached over an untrusted network in stage/prod.
export MY_PROJECT_API_POSTGRESQL_SSL_MODE="disable"

export MY_PROJECT_API_RABBITMQ_HOST="localhost"
# Port comes from env/<env>/ports.env, sourced by Makefile.
export MY_PROJECT_API_RABBITMQ_VHOST="my_project"
export MY_PROJECT_API_RABBITMQ_USER="my_project"
export MY_PROJECT_API_RABBITMQ_PASS="password"
export MY_PROJECT_API_RABBITMQ_CONNECT_TIMEOUT="10s"

export MY_PROJECT_API_REDIS_HOST="localhost"
# Port comes from env/<env>/ports.env, sourced by Makefile.
export MY_PROJECT_API_REDIS_DB="0"
export MY_PROJECT_API_REDIS_USER="my_project"
export MY_PROJECT_API_REDIS_PASS="password"

# note domain: Redis cache-aside TTL for note reads (0 = no expiry).
export MY_PROJECT_API_NOTE_CACHE_TTL="60s"

# Domain events: RabbitMQ topic exchange + routing/queue names. The note domain
# publishes note.created here; the consumer worker binds NOTE_WORKER_QUEUE to it.
export MY_PROJECT_API_EVENTS_EXCHANGE="my_project.events"
export MY_PROJECT_API_EVENTS_NOTE_CREATED_KEY="note.created"
export MY_PROJECT_API_EVENTS_NOTE_WORKER_QUEUE="note.created.worker"

# JWT signing. SECRET is required (no default) — the backend fails fast at
# startup if empty. The value below is "password" so `make gen-env` replaces it
# with a random 32-byte hex secret, same as the other credentials.
export MY_PROJECT_API_JWT_SECRET="password"
export MY_PROJECT_API_JWT_ACCESS_TTL="15m"
export MY_PROJECT_API_JWT_REFRESH_TTL="720h"

# Per-IP rate limit on the auth endpoints (register/login/refresh).
export MY_PROJECT_API_AUTH_RATE_LIMIT_MAX="10"
export MY_PROJECT_API_AUTH_RATE_LIMIT_WINDOW="1m"

# Optional S3 / object storage. Leave blank unless you wire an S3 component.
export MY_PROJECT_API_S3_ENDPOINT=""
export MY_PROJECT_API_S3_REGION=""
export MY_PROJECT_API_S3_KEY_ID=""
export MY_PROJECT_API_S3_SECRET=""
export MY_PROJECT_API_S3_PRESIGNED_TTL="10m"
